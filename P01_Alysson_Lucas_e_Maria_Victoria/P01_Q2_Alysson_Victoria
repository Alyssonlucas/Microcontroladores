		;		INSTRUÇÕES UTILIZADAS
		;		'LDR' (Load Register) significa Carregar Registrador
		;		- É uma função permitida no visUAL para o assembly
		;		- Entretanto, precisa acessar a memória, que não é o objetivo desta prática
		;		- Utilizada apenas para armazenar o endereço de memória
		;		'MOV' (Move) siginifica Mover
		;		- Permite carregar diretamente valores pequenos nos registradores
		;		- Executa em 1 ciclo de máquina, pois não precisa acessar a RAM
		;		'STR' (Store Register) significa Armazenar Registrador
		;		- Move dados de um registrador para um endereço de memória específico
		;		'ADD' opera a adição
		;		- O primeiro termo recebe a soma entre o segundo e o terceiro
		;		'SUB' opera a subtração
		;		- O primeiro termo recebe a subtração do terceiro pelo segundo
		;		'CMP' faz uma comparação
		;		'BGT' (Branch if Greater Than) significa Desviar se Maior Que
		;		- Se atendida a condição, desvia o código para o rótulo indicado
		
		;		SEQUÊNCIA DE FIBONACCI
		;		F(0) = 1 e F(1) = 1
		;		F(n) = F(n-1) + F(n-2)
		
		MOV		R0, #1		; R0 é o F(n-2), começando em 1
		MOV		R1, #1		; R1 é o F(n-1), começando em 1
		MOV		R3, #20		; R3 é o contador do laço (para 20 termos)
		LDR		R13, =0x100	; Armazena o endereço de memória 0x100 em R13 (ponteiro)
		
fibonacci	;		Cria um rótulo chamado "fibonacci"
		
		;		--- SALVAR NA MEMÓRIA ---
		STR		R0, [R13]		; Armazena o valor atual de R0 no endereço 0x100
		ADD		R13, R13, #4	; Avança o ponteiro em 4 bytes (próxima posição),
		;		deixando um espaço livre para o armazenamento do próximo valor de R0
		
		;		--- CALCULAR O PRÓXIMO TERMO ---
		ADD		R2, R0, R1	; Aplica a fórmula: R2 = R0 + R1
		
		;		--- ATUALIZAR OS VALORES ---
		MOV		R0, R1		; O antigo F(n-1) vira o novo F(n-2)
		MOV		R1, R2		; O termo recém-calculado vira o novo F(n-1)
		
		;		--- CONTROLAR O LAÇO ---
		SUB		R3, R3, #1	; Diminui 1 do contador
		CMP		R3, #0		; Compara o contador com zero
		BGT		fibonacci		; Se for Maior que Zero, desvia o código para o rótulo "fibonacci"
		;		Isso quer dizer reiniciar o código para encontrar mais termos

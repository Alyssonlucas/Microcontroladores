			;		Autores:	Alysson Lucas Pontes Cavalcante da Silva e Maria Victória Martins Neves.
			
			
			;		--- DEFINIÇÕES DOS TERMOS
			;		'MOV' movimenta os valores desejados para os registradores
			;		'LDR' funciona de forma semelhante ao MOV, mas para valores maiores
			
			MOV		R0, #20		; Primeiro termo 'm'
			MOV		R1, #8		; Segundo termo 'n'
			
			LDR		R13, =0x100	; Endereçamento de memória para salvar o MDC no final
			
MDC
			;		--- VERIFICAÇÃO DA BASE (if n == 0)
			;		'CMP' faz uma comparação
			;		'BEQ' significa Branch if Equal (Se igual)
			
			CMP		R1, #0		; Verifica se o segundo termo zerou
			BEQ		fim_mdc		; Se n=0, o MDC é o 'm' (R0) e o código pula pro fim
			
			;		--- CALCULANDO O RESTO (m % n)
resto	;		'BLT' significa "Salte se menor que" (Branch if Less Than)
			CMP		R0, R1		; Compara 'm' com 'n'
			BLT		atualiza_vars	; Se 'm' ficou menor que 'n', a divisão acabou. O que sobrou em R0 é o Resto!
			SUB		R0, R0, R1	; Subtrai 'n' de 'm' (m = m - n)
			B		resto	; Volta para continuar subtraindo
			
atualiza_vars
			;		--- SIMULANDO A RECURSÃO (euclides_mdc(n, m % n)) ---
			;		Precisamos que: Novo_m = n_antigo  |  Novo_n = resto
			MOV		R2, R1		; Salva o 'n' antigo (R1) no R2 para não perde-lo
			MOV		R1, R0		; O Novo 'n' (R1) recebe o Resto (que estava no R0)
			MOV		R0, R2		; O Novo 'm' (R0) recebe o 'n' antigo (que guardamos no R2)
			
			B		MDC	; Volta para o topo do algoritmo com os novos valores!
			
fim_mdc
			;		--- SALVANDO O RESULTADO ---
			STR		R0, [R13]	; Salva o MDC final na memória

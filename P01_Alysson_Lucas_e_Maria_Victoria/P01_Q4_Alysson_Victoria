			;		MULTIPLICAÇÃO EM BAIXO NÍVEL
			;		Repitidas somas através de laços de repetição
			
			;		--- DEFINIÇÃO DOS TERMOS
			;		'MOV' movimenta os valores desejados para os registradores
			;		'LDR' funciona de forma semelhante ao MOV, mas para valores maiores
			MOV		R0, #5		; Primeiro termo (Fator)
			MOV		R1, #4		; Segundo termo (Fator), atuará como contador
			MOV		R2, #0		; Acumulador (Resultado), começa zerado
			LDR		R13, =0x100	; Endereço de memória para salvar no final
			
multiplicacao
			;		--- CONDIÇÃO DE PARADA
			;		'CMP' faz uma comparação
			;		'BEQ' significa Branch if Equal (Desvie se igual)
			CMP		R1, #0		; Verifica se o contador zerou
			BEQ		fim			; Se o contador chegou em zero, o código pula para o fim
			
			;		--- SOMAS SUCESSIVAS
			;		'ADD' opera a adição, o primeiro termo recebe a soma entre o segundo e o terceiro
			;		'SUB' opera a subtração, o primeiro é a subtração do terceiro pelo segundo
			ADD		R2, R2, R0	; Soma o Fator (R0) no Acumulador (R2)
			SUB		R1, R1, #1	; Tira 1 do Contador (R1)
			B		multiplicacao	; Volta pro início do laço
			
fim
			;		--- REGISTRO DO RESULTADO NA MEMÓRIA
			STR		R2, [R13]        ; Salva o resultado (R2) na memória

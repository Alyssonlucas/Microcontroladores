			;		INSTRUÇÕES UTILIZADAS
			;		'LDR' (Load Register) significa Carregar Registrador
			;		- É uma função permitida no visUAL para o assembly
			;		- Entretanto, precisa acessar a memória, que não é o objetivo desta prática
			;		- Utilizada apenas para armazenar o endereço de memória
			;		'MOV' (Move) siginifica Mover
			;		- Permite carregar diretamente valores pequenos nos registradores
			;		- Executa em 1 ciclo de máquina, pois não precisa acessar a RAM
			;		'STR' (Store Register) significa Armazenar Registrador
			;		- Move dados de um registrador para um endereço de memória específico
			;		'ADD' opera a adição
			;		- O primeiro termo recebe a soma entre o segundo e o terceiro
			;		'SUB' opera a subtração
			;		- O primeiro termo recebe a subtração do terceiro pelo segundo
			;		'CMP' faz uma comparação
			;		'BEQ' (Branch if Equal) significa Desvie se Igual
			;		- Se atendida a condição, desvia o código para o rótulo indicado
			;		'B' (Branch) siginica Saltar
			;		- Desvia o código para o rótulo indicado independentemente de condição
			
			;		MULTIPLICAÇÃO EM BAIXO NÍVEL
			;		Repitidas somas através de laços de repetição
			
			;		--- DEFINIÇÃO DOS TERMOS ---
			MOV		R0, #65		; Primeiro termo (Fator) da multiplicação
			MOV		R1, #11		; Segundo termo (Fator) da multiplicação,
			;		atuará como contador e, consequentemente, não terá valor salvo ao fim
			MOV		R2, #0		; Acumulador (Resultado), começa zerado
			LDR		R13, =0x100	; Armazena o endereço de memória 0x100 em R13 (ponteiro)
			
multiplicacao	;		Cria um rótulo chamado "multiplicacao"
			
			;		--- CONDIÇÃO DE PARADA ---
			CMP		R0, #0		; Verifica se o primeiro termo é zero
			BEQ		fim			; Se R0 = 0, desvia o código para o rótulo "fim"
			CMP		R1, #0		; Verifica se o segundo termo é zero ou se o contador zerou
			BEQ		fim			; Se R1 = 0, desvia o código para o rótulo "fim"
			
			;		--- SOMAS SUCESSIVAS ---
			ADD		R2, R2, R0	; Soma o Fator (R0) no Acumulador (R2)
			SUB		R1, R1, #1	; Diminui "1" do Contador (R1)
			B		multiplicacao	; Desvia o código para o rótulo "multiplicacao"
			;		Isso quer dizer continuar com as somas sucessivas
			
fim			;		Cria um rótulo chamado "fim"
			
			;		--- REGISTRO DO RESULTADO NA MEMÓRIA ---
			STR		R2, [R13]        ; R2 lê e salva o valor registrado no enderço 0x100

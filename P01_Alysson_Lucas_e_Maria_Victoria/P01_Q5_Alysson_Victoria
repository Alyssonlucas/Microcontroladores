			;		INSTRUÇÕES UTILIZADAS
			;		'LDR' (Load Register) significa Carregar Registrador
			;		- É uma função permitida no visUAL para o assembly
			;		- Entretanto, precisa acessar a memória, que não é o objetivo desta prática
			;		- Utilizada apenas para armazenar o endereço de memória
			;		'MOV' (Move) siginifica Mover
			;		- Permite carregar diretamente valores pequenos nos registradores
			;		- Executa em 1 ciclo de máquina, pois não precisa acessar a RAM
			;		'MOVLE' (Move If Less or Equal) siginifica Mover Se Menor ou Igual
			;		- Carrega valores apenas se a condição anterior for atendida
			;		'STR' (Store Register) significa Armazenar Registrador
			;		- Move dados de um registrador para um endereço de memória específico
			;		'ADD' opera a adição
			;		- O primeiro termo recebe a soma entre o segundo e o terceiro
			;		'SUB' opera a subtração
			;		- O primeiro termo recebe a subtração do terceiro pelo segundo
			;		'CMP' faz uma comparação
			;		'BEQ' (Branch if Equal) significa Desvie se Igual
			;		- Se atendida a condição, desvia o código para o rótulo indicado
			;		'BLE' (Branch if Less or Equal) significa Desviar se Menor ou Igual a
			;		- Se atendida a condição, desvia o código para o rótulo indicado
			;		'B' (Branch) siginica Saltar
			;		- Desvia o código para o rótulo indicado independentemente de condição
			
			;		FATORIAL
			;		Repitidas multiplicações através de somas
			;		Cada registrador possui 32 bits = 4 bytes
			;		Haverá Overflow do resultado para valores que ocupem mais que 32 bits
			;		Maior valor possível de ser registrado: 2^{32} = 4.294.967.296
			;		12! = 479.001.600 (Cabe com folga, é menor que 4 bilhões)
			;		13! = 6.227.020.800 (Estouro o limite, o resultado apresentará erro)
			
			;		--- DEFINIÇÃO DO FATORIAL E ENDEREÇAMENTO  ---
			MOV		R0, #12		; O número que se deseja obter o fatorial (R0)
			LDR		R13, =0x200	; Armazena o endereço de memória 0x100 em R13 (ponteiro)
			
			;		--- CASOS ESPECIAIS ---
			CMP		R0, #1		; Verifica se o número (R0) é 0 ou 1
			MOVLE	R4, #1		; Se R0 for menor ou igual a 1, O resultado (R4) é 1
			BLE		fim_fat		; Se R0 for menor ou igual a 1, encerra o fatorial
			
			;		--- DEFINIÇÃO DOS TERMOS DO FATORIAL ---
			SUB		R1, R0, #1	; R1 é o multiplicador (R1 = R0 - 1)
			MOV		R4, R0		; R4 é o acumulador, recebe o resultado
			
fatorial	;		Cria um rótulo chamado "fatorial"
			;		--- LAÇO EXTERNO (multiplicações sucessivas) ---
			CMP		R1, #1		; Verifica se todos os termos já foram multiplicados
			BEQ		fim_fat		; Se sim (R1 = 1), encerra o fatorial
			
			;		--- DEFINIÇÃO DOS TERMOS DA MULTIPLICAÇÃO ---
			MOV		R2, R1		; R2 é o contador de somas = multiplicador atual
			MOV		R3, #0		; R3 é o acumulador temporário da soma (zera a cada ciclo)
			
multiplicacao	;		Cria um rótulo chamado "multiplicacao"
			;		--- LAÇO INTERNO (somas sucessivas) ---
			CMP		R2, #0		; Verifica se todos os termos já foram somados
			BEQ		fim_mult		; Se sim (R2 = 0), encerra a multiplicação
			ADD		R3, R3, R4	; Soma o valor atual do acumulador (R4) no temporário (R3)
			SUB		R2, R2, #1	; Decrementa 1 do contador
			B		multiplicacao	; Reinicia a multiplicação
			
fim_mult	;		Cria um rótulo chamado "fim_mult"
			;		--- ATUALIZAÇÃO DO FATORIAL ---
			MOV		R4, R3		; O Acumulador Final (R4) recebe o resultado das somas (R3)
			SUB		R1, R1, #1	; Diminui o multiplicador principal (R1)
			B		fatorial		; Retorna ao início para continuar a contagem do fatorial
			
fim_fat		;		Cria um rótulo chamado "fim_fat"
			;		--- SALVAR NA MEMÓRIA ---
			STR		R4, [R13]		; Salva o resultado final do fatorial (R4) na memória

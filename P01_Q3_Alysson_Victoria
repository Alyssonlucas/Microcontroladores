		;		OVERFLOW DOS REGISTRADORES
		;		Tamanho dos registradores: 32 bits = 8 bytes
		;		Maior inteiro positivo: 2^{32} - 1 = 4.294.967.295
		
		;		'MOV' movimenta os valores desejados para os registradores
		;		'LDR' funciona de forma semelhante ao MOV, mas para valores maiores
		MOV		R0, #1		; R0 é o F(n-2), começando com 1
		MOV		R1, #1		; R1 é o F(n-1), começando com 1
		LDR		R13, =0x100	; R13 é o apontador de memória
		MOV		R3, #1		; R3 é o contador do laço
		
fibonacci
		;		--- SALVAR NA MEMÓRIA
		;		'STR' significa Store Register (Armazenar Registrador)
		;		'ADD' opera a adiçăo, o primeiro termo recebe a soma entre o segundo e o terceiro
		STR		R0, [R13]		; Salva o valor atual de R0 na memória
		ADD		R13, R13, #4	; Avança o apontador de memória em 4 bytes (próxima posiçăo)
		
		;		--- CALCULAR O PRÓXIMO TERMO
		;		'ADDS' opera a adiçăo, mas caso ultrapasse 32 bits, a Flag C vira 1 (Carry Flag, ou flag C)
		;		'BCS' significa Branch if Carry Set (Salte se o Carry for 1)
		ADDS		R2, R0, R1	; Aplica a fórmula: R2 = R0 + R1
		BCS		fim				; Se R2 de overflow, o código sai do laço e pula para o final
		
		;		--- ATUALIZAR OS VALORES
		MOV		R0, R1		; O antigo F(n-1) vira o novo F(n-2)
		MOV		R1, R2		; O termo recém-calculado vira o novo F(n-1)
		ADD		R3, R3, #1	; Contabiliza quantos termos já foram encontrados
		B		fibonacci			; Volta para o começo do laço para calcular o próximo número
fim
		
		;		--- REGISTRAR O RESULTADO NA MEMÓRIA
		STR		R3, [R2]
